# Preferred summary model endpoint (recommended: GLM/OpenAI compatible)
SUMMARY_API_KEY=
SUMMARY_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
SUMMARY_MODEL=glm-5
# Optional: smaller batch improves stability under API load
SUMMARY_BATCH_SIZE=3

# Backward compatibility: Kimi / Moonshot (optional fallback)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
KIMI_BATCH_SIZE=3

# GitHub API token (optional but recommended to avoid rate limits)
GITHUB_TOKEN=

# Telegram (to be configured later)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional for Telegram forum topics (e.g. 29)
TELEGRAM_THREAD_ID=

# Optional: restrict sending to specific chat/thread for security
# If set, the bot will only send messages to this specific chat/thread
# REQUIRED_TELEGRAM_CHAT_ID=-1003826061483
# REQUIRED_TELEGRAM_THREAD_ID=29

# Public app URL used in Telegram message footer
APP_BASE_URL=https://your-vercel-app.vercel.app

# Feishu (Lark) App Bot - WebSocket/Long Connection Mode
# Create app at: https://open.feishu.cn/app -> Enterprise Self-Built App
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED: Target group chat ID (群聊ID，必须设置！)
# Get chat_id from: Feishu Admin -> Groups -> Group Details
# Format: oc_xxxxxxxxxxxxxxxx
FEISHU_CHAT_ID=oc_xxxxxxxxxxxx
