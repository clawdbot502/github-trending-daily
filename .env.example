# Kimi / Moonshot (AI summary)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
# Optional: smaller batch improves stability under API load
KIMI_BATCH_SIZE=3

# GitHub API token (optional but recommended to avoid rate limits)
GITHUB_TOKEN=

# Telegram (to be configured later)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional for Telegram forum topics (e.g. 29)
TELEGRAM_THREAD_ID=

# Public app URL used in Telegram message footer
APP_BASE_URL=https://your-vercel-app.vercel.app
